  "keyFeatures": [
    "Complete tournament management system with teams, players, and matches",
    "Entity Framework Core with SQLite/SQL Server support",
    "ASP.NET Core Identity for user authentication and authorization",
    "Docker containerization with multi-environment support",
    "Repository pattern for data access with comprehensive CRUD operations",
    "Razor Pages frontend with responsive design"
  ],
  "publicApiSurface": [
    "DirectorTecnico - Technical director entity with validation",
    "Equipo - Team entity with relationships to players and matches",
    "Jugador - Player entity with position and team associations",
    "Municipio - Municipality entity for team locations",
    "Partido - Match entity tracking local and visiting teams",
    "Posicion - Player position entity",
    "IRepositorioDT - Technical director repository interface",
    "IRepositorioEquipo - Team repository interface",
    "IRepositorioJugador - Player repository interface",
    "IRepositorioMunicipio - Municipality repository interface",
    "IRepositorioPartido - Match repository interface",
    "IRepositorioPosicion - Position repository interface",
    "DataContext - Entity Framework database context"
  ]
}
